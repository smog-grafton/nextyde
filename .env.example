# Telegram (required)
TG_API_ID=31531320
TG_API_HASH=eb69412c522ef07faf710356224b0ff6
TG_PHONE=+256702093354
# Optional: session name (default: narabox_data_pipe)
TG_SESSION_NAME=narabox_telebot
# Optional: if 2FA is enabled
TG_2FA_PASSWORD=
# Optional: for headless first-time login (e.g. Docker)
TG_LOGIN_CODE=

# Watch / join targets (comma-separated)
# e.g. @jozzmovies or https://t.me/+invitehash
TG_WATCH_TARGETS=@jozzmovies
TG_JOIN_TARGETS=

# Paths
TEMP_DIR=/tmp/telebot
DB_PATH=./telebot_state.db
PORT=8765

# Logging
LOG_LEVEL=INFO

# Concurrency and scan
MAX_CONCURRENT_DOWNLOADS=1
MAX_CONCURRENT_TRANSCODES=1
WEB_MAX_ACTIVE_JOBS=3
WEB_RECENT_JOB_RETENTION_HOURS=24
# Messages to scan on startup (0 = only new messages and pasted links, no catch-up)
SCAN_LAST_MESSAGES=15
DOWNLOAD_CHUNK_SIZE=1048576
POLL_INTERVAL_SECONDS=30

# Cleanup
DELETE_AFTER_UPLOAD=true
TEMP_FILE_TTL_HOURS=24

# Download-only mode: no CDN upload; telebot fetches the original Telegram file and exposes a temp link you can paste into another fetch tool, then click Destroy
DOWNLOAD_ONLY=false
# When using Download only: public URL of this app so the temp file link works.
# Use the same URL you use in the browser to open the Web UI (with or without trailing slash).
# Examples: https://teletyde.example.com   https://myapp.157.173.104.218.sslip.io
TEMP_PUBLIC_URL=
# Optional secret for signed temp URLs used by CDN_HANDOFF_MODE=source_url.
# If blank, the app reuses CDN_API_TOKEN.
TEMP_URL_SECRET=

# Video preparation (used for normal upload/handoff jobs; download-only keeps the original Telegram file as-is)
VIDEO_PREP_ENABLED=true
VIDEO_PREP_MAX_HEIGHT=720
VIDEO_PREP_CRF=22
VIDEO_PREP_PRESET=superfast
VIDEO_PREP_MIN_SIZE_MB_FOR_TRANSCODE=50
VIDEO_PREP_TARGET_MAX_MB=1024
VIDEO_PREP_CAP_HEIGHT_LADDER=480,360
VIDEO_PREP_KEEP_ORIGINAL_ON_SUCCESS=false
VIDEO_PREP_TIMEOUT_SECONDS=21600
# Optional binary overrides (otherwise resolved from PATH)
FFMPEG_BINARY=
FFPROBE_BINARY=

# CDN: telegram-intake endpoint (required unless DOWNLOAD_ONLY=true)
CDN_UPLOAD_URL=http://127.0.0.1:8012/api/v1/media/telegram-intake
CDN_API_TOKEN=gMGMD92sagXVlgRI8jAFdMX2tnWRiqtHXvHlCaT0V1rAxXeschuUeJlsdn56Nlhm
CDN_TIMEOUT_SECONDS=3600
CDN_SOURCE=telegram
CDN_HANDOFF_MODE=path_copy
# Options: upload, path_copy, source_url
CDN_SHARED_INTAKE_ROOT=/Applications/XAMPP/xamppfiles/htdocs/ffmpeg-worker/storage/app/telegram-intake
CDN_SHARED_INTAKE_DISK=telegram-intake
WORKER_HANDLES_VIDEO_PREP=true
# Optional: run the web app as a temp-file server only, without logging in to Telegram.
WEB_DISABLE_TELEGRAM=false

# Portal: ingest-notify endpoint (optional)
CDN_NOTIFY_URL=http://127.0.0.1:8000/api/telegram/ingest-notify
CDN_NOTIFY_TOKEN=6559284753:AAFf81Dz_EiQ3w6O9wz0-nqWt0h4b6TzvJQ

# Defaults for metadata (optional)
DEFAULT_CATEGORY=
DEFAULT_LANGUAGE=
DEFAULT_VJ=
