# Telegram (required)
TG_API_ID=31531320
TG_API_HASH=eb69412c522ef07faf710356224b0ff6
TG_PHONE=+256702093354
# Optional: session name (default: narabox_data_pipe)
TG_SESSION_NAME=narabox_telebot
# Optional: if 2FA is enabled
TG_2FA_PASSWORD=
# Optional: for headless first-time login (e.g. Docker)
TG_LOGIN_CODE=

# Watch / join targets (comma-separated)
# e.g. @jozzmovies or https://t.me/+invitehash
TG_WATCH_TARGETS=@jozzmovies
TG_JOIN_TARGETS=

# Paths
TEMP_DIR=/tmp/telebot
DB_PATH=./telebot_state.db

# Logging
LOG_LEVEL=INFO

# Concurrency and scan
MAX_CONCURRENT_DOWNLOADS=1
# Messages to scan on startup (0 = only new messages and pasted links, no catch-up)
SCAN_LAST_MESSAGES=15
DOWNLOAD_CHUNK_SIZE=1048576
POLL_INTERVAL_SECONDS=30

# Cleanup
DELETE_AFTER_UPLOAD=true

# CDN: telegram-intake endpoint (required)
CDN_UPLOAD_URL=http://127.0.0.1:8001/api/v1/media/telegram-intake
CDN_API_TOKEN=gMGMD92sagXVlgRI8jAFdMX2tnWRiqtHXvHlCaT0V1rAxXeschuUeJlsdn56Nlhm
CDN_TIMEOUT_SECONDS=3600
CDN_SOURCE=telegram

# Portal: ingest-notify endpoint (optional)
